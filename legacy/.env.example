# Application environment: development | production
# Controls Twig debug/auto_reload and error display.
APP_ENV=development

POSTMARK_API_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# "From" address used for outgoing notification emails.
MAIL_FROM_ADDRESS="notifications@example.com"
# Comma-separated list of recipients for admin notifications (e.g. login alerts).
ADMIN_NOTIFICATION_EMAILS="admin@example.com"

SITE_OWNER="Your Name"
SITE_NAME="Your Site"
SITE_TAGLINE="Your Site's Tagline"

SITE_DESCRIPTION="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
SITE_AUTHOR="Your Name"

DB_SERVER="db"
DB_USER="root"
DB_PASS="root"
DB_NAME="db"