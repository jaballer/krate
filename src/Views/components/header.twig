<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand" href="{{ url_for('/index.php') }}">
                {% if site.logo_url is defined and site.logo_url %}
                    <img class="logo"
                         src="{{ site.logo_url }}"
                         alt="{{ site.name|default(site_name) }}"
                         height="30">
                {% else %}
                    {{ site.name|default(site_name) }}
                {% endif %}
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto">
                    {% if is_admin %}
                        <li class="nav-item">
                            <a href="{{ url_for('/admin/dashboard') }}" class="btn btn-secondary">
                                Admin Dashboard
                            </a>
                        </li>
                    {% endif %}
                    {% if is_logged_in %}
                        <li class="nav-item">
                            <form method="post" action="/users/logout.php" class="d-inline-block mb-0">
                                {{ csrf_field()|raw }}
                                <button type="submit" class="btn btn-danger ml-2">Log Out</button>
                            </form>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a class="btn btn-primary ml-2" href="/users/login.php">Log In</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>
</header>

{% if is_admin %}
    {# Admin sub-navigation (ported from templates/components/nav_admins.php) #}
    <div class="bg-dark">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <ul class="nav justify-content-center">
                        <li class="nav-item">
                            <a id="nav-item-users" class="text-white nav-link" href="/users/">Users</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endif %}

{# Flash message (read-and-clear; renders only when a page actually renders the layout) #}
{% set flash = get_flash() %}
{% if flash %}
    <div id="message" class="alert alert-success container" role="alert">
        {{ flash }}
    </div>
{% endif %}
