{% extends 'templates/base.twig' %}

{% block title %}{{ page_title }} | {{ site_name }}{% endblock %}

{% block styles %}
<style>
    .record-img {
        margin-bottom: 1rem;
        max-width: 560px;
        transition: transform 0.5s ease-in-out, border-radius 0.5s ease-in-out;
    }

    .rotate {
        animation: spin 4s linear infinite;
        border-radius: 100%;
    }

    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>
{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">{{ record.title }}</h1>
        </div>

        <div id="record-img-audio" class="col-12 col-lg-6">
            {% if record.frontImage %}
                <img class="record-img record-img-front"
                     src="{{ url_for('/uploads/' ~ record.frontImage|split('/')|last) }}"
                     alt="Front of Record">
                <p>Front Image</p>
            {% else %}
                <img class="record-img record-img-front"
                     src="{{ url_for('/assets/images/vinyl-record.png') }}"
                     alt="Placeholder Record Image">
                <p>Placeholder Image</p>
            {% endif %}

            {% if record.backImage %}
                <img class="record-img record-img-front"
                     src="{{ url_for('/uploads/' ~ record.backImage|split('/')|last) }}"
                     alt="Back of Record">
                <p>Back Image</p>
            {% endif %}

            {% if record.audioFileUrl %}
                <div class="mb-4">
                    <audio class="audio-player" controls loop>
                        <source src="{{ record.audioFileUrl }}" type="audio/mp3">
                    </audio>
                </div>
            {% endif %}

            {% if record.purchaseLink %}
                <div class="d-lg-none mb-4 mb-lg-0">
                    <a href="{{ record.purchaseLink }}" target="_blank" class="btn btn-primary">Purchase</a>
                </div>
            {% endif %}

            <div class="col-12 actions mb-5">
                <a class="btn btn-outline-info font-weight-bold" href="{{ url_for('/index.php') }}">&laquo; Back to List</a>
                {% if is_logged_in %}
                    <a class="btn btn-warning" href="{{ url_for('/records/edit.php?id=' ~ record.id) }}">Edit Record</a>
                    <a class="btn btn-danger" href="{{ url_for('/records/delete.php?id=' ~ record.id) }}">Delete Record</a>
                {% endif %}
            </div>
        </div>

        <div id="record-details" class="col-12 col-lg-6">
            <p class="h3"><strong>Title:</strong> {{ record.title }}</p>
            <p class="h4"><strong>Artist:</strong> {{ record.artist }}</p>

            <div class="details mb-4">
                {% if record.genre %}<div><strong>Genre:</strong> {{ record.genre }}</div>{% endif %}
                {% if record.releaseYear %}<div><strong>Release Year:</strong> {{ record.releaseYear }}</div>{% endif %}
                {% if record.label %}<div><strong>Label:</strong> {{ record.label }}</div>{% endif %}
                {% if record.catalogNumber %}<div><strong>Catalog Number:</strong> {{ record.catalogNumber }}</div>{% endif %}
                {% if record.format %}<div><strong>Format:</strong> {{ record.format }}</div>{% endif %}
                {% if record.speed %}<div><strong>Speed:</strong> {{ record.speed }}</div>{% endif %}
                {% if record.bpm %}<div><strong>Beats Per Minute:</strong> {{ record.bpm }}</div>{% endif %}
                {% if record.condition %}<div><strong>Condition:</strong> {{ record.condition }}</div>{% endif %}
                {% if record.purchaseDate %}<div><strong>Purchase Date:</strong> {{ record.purchaseDate }}</div>{% endif %}
                {% if record.purchasePrice %}<div><strong>Purchase Price:</strong> ${{ record.purchasePrice|number_format(2) }}</div>{% endif %}
                {% if record.notes %}<p><strong>Notes:</strong> {{ record.notes }}</p>{% endif %}
            </div>

            {% if record.purchaseLink %}
                <div>
                    <a href="{{ record.purchaseLink }}" target="_blank" class="btn btn-primary">Purchase</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const audioPlayer = document.querySelector('.audio-player');
        const recordImage = document.querySelector('.record-img-front');

        if (audioPlayer && recordImage) {
            audioPlayer.addEventListener('play', function () {
                recordImage.classList.add('rotate');
            });

            audioPlayer.addEventListener('pause', function () {
                recordImage.classList.remove('rotate');
            });

            audioPlayer.addEventListener('ended', function () {
                recordImage.classList.remove('rotate');
            });
        }
    });
</script>
{% endblock %}
