{% extends 'templates/base.twig' %}

{% block title %}{{ hero_title|default(site_name) }}{% endblock %}

{% block content %}
<div class="hero">
    <div class="jumbotron jumbotron-fluid px-4">
        <div class="container text-center">
            <h1 class="display-4">{{ hero_title }}</h1>
            <p class="lead">{{ hero_tagline }}</p>

            {# Search Form #}
            <form class="form-inline d-block mx-auto" action="index.php" method="GET">
                <input type="text"
                       name="search"
                       class="form-control mr-2 mb-2 mb-md-0"
                       placeholder="Search by Title or Artist"
                       value="{{ search_term }}">
                <button type="submit" class="btn btn-primary">Search</button>
                <a href="index.php" class="btn btn-outline-secondary ml-2">Clear</a>
            </form>
        </div>
    </div>
</div>

<div class="container record-table-container py-4 mb-5">
    <div class="row">
        <div class="col-12 col-md-6">
            <h2>All Vinyl Records</h2>
        </div>

        {% if is_logged_in %}
            <div class="col-12 col-md-6">
                <div class="action text-right">
                    <a class="btn btn-primary mb-4" href="{{ url_for('records/add.php') }}">Add New Record</a>
                </div>
            </div>
        {% endif %}
    </div>

    <div class="row">
        <div class="col-12">
            <section class="record-table">
                {% if records is not empty %}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Artist</th>
                                <th>Release Year</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for record in records %}
                                <tr>
                                    <td>
                                        <a href="{{ url_for('/records/details.php?id=' ~ record.id) }}">{{ record.title }}</a>
                                    </td>
                                    <td>{{ record.artist }}</td>
                                    <td>{{ record.releaseYear }}</td>
                                    <td>
                                        <a href="{{ url_for('/records/details.php?id=' ~ record.id) }}" class="btn btn-info btn-sm">View Details</a>
                                        {% if is_logged_in %}
                                            <a href="{{ url_for('/records/edit.php?id=' ~ record.id) }}" class="btn btn-secondary btn-sm ml-1 mr-2">Edit Details</a>
                                            <a href="{{ url_for('/records/delete.php?id=' ~ record.id) }}" class="btn btn-danger btn-sm">Delete Record</a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p>No records found.</p>
                {% endif %}
            </section>
        </div>
    </div>
</div>
{% endblock %}
